---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SchemaJsonLd from '../components/SchemaJsonLd.astro';
import { orgSchema, websiteSchema } from '../lib/schema';
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
  schema?: unknown[];
}
const { title, description, canonical, noindex, ogImage, schema = [] } = Astro.props as Props;
const url = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();
const og = ogImage ?? '/og-default.png';
const allSchema = [orgSchema(), websiteSchema(), ...schema].filter(Boolean);
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={url} />
  {noindex && <meta name="robots" content="noindex,follow" />}
  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={new URL(og, SITE.url).toString()} />
  <meta property="og:locale" content={SITE.locale} />
  <meta property="og:site_name" content={SITE.name} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <SchemaJsonLd data={allSchema as Record<string, unknown>[]} />
  <slot name="head" />
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
