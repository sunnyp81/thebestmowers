---
interface Props {
  rank: number;
  name: string;
  brand: string;
  bestFor: string;
  rating: number;
  pros: string[];
  cons: string[];
  rrp?: string;
  reviewUrl: string;
  affiliateUrl?: string;
  image?: string;
  verdict: string;
}
import { AFFILIATE_REL } from '../lib/affiliate';
const { rank, name, brand, bestFor, rating, pros, cons, rrp, reviewUrl, affiliateUrl, image, verdict } = Astro.props as Props;
---
<article class="border border-slate-200 rounded-xl bg-white overflow-hidden shadow-sm">
  <div class="grid md:grid-cols-[200px_1fr] gap-0">
    <div class="bg-grass-50 flex items-center justify-center p-6 md:p-4 relative">
      <span class="absolute top-3 left-3 bg-grass-700 text-white text-xs font-bold px-2 py-1 rounded">#{rank}</span>
      {image ? (
        <img src={image} alt={name} loading="lazy" width="180" height="180" class="object-contain max-h-44" />
      ) : (
        <div class="w-32 h-32 rounded-lg bg-grass-200 flex items-center justify-center text-grass-700 text-3xl font-bold">{brand.slice(0,1)}</div>
      )}
    </div>
    <div class="p-5">
      <div class="flex items-start justify-between gap-3 mb-2">
        <div>
          <span class="inline-block text-xs font-semibold text-grass-700 uppercase tracking-wide mb-1">Best for {bestFor}</span>
          <h3 class="text-xl font-bold text-soil-900 leading-tight">{name}</h3>
          <p class="text-sm text-slate-500">{brand}</p>
        </div>
        <div class="text-right shrink-0">
          <div class="text-amber-500 text-lg" aria-label={`${rating} out of 5`}>
            {'★'.repeat(Math.round(rating))}<span class="text-slate-300">{'★'.repeat(5 - Math.round(rating))}</span>
          </div>
          {rrp && <div class="text-sm font-semibold text-soil-900 mt-1">{rrp}</div>}
        </div>
      </div>
      <p class="text-slate-700 text-sm md:text-base mb-4 leading-relaxed">{verdict}</p>
      <div class="grid sm:grid-cols-2 gap-3 mb-4 text-sm">
        <div>
          <h4 class="font-semibold text-grass-700 mb-1">Pros</h4>
          <ul class="space-y-0.5 text-slate-700">{pros.map((p) => (<li>+ {p}</li>))}</ul>
        </div>
        <div>
          <h4 class="font-semibold text-red-700 mb-1">Cons</h4>
          <ul class="space-y-0.5 text-slate-700">{cons.map((c) => (<li>− {c}</li>))}</ul>
        </div>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href={reviewUrl} class="inline-flex items-center gap-1 text-sm font-semibold text-grass-700 hover:text-grass-900 underline underline-offset-2">Read full review →</a>
        {affiliateUrl && (
          <a href={affiliateUrl} rel={AFFILIATE_REL} target="_blank" class="ml-auto inline-flex items-center gap-1 text-sm font-semibold bg-grass-700 hover:bg-grass-800 text-white px-3 py-1.5 rounded min-h-[44px]">
            Check price on Amazon
          </a>
        )}
      </div>
    </div>
  </div>
</article>
