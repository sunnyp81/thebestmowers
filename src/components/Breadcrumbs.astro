---
interface Props { items: { name: string; url: string }[]; }
const { items } = Astro.props as Props;
---
<nav aria-label="Breadcrumb" class="text-sm text-slate-500 mb-6">
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        {i < items.length - 1 ? (
          <>
            <a href={item.url} class="hover:text-grass-700 underline-offset-2 hover:underline">{item.name}</a>
            <span aria-hidden="true">/</span>
          </>
        ) : (
          <span class="text-soil-900 font-medium" aria-current="page">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
