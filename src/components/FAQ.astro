---
interface Props { faqs: { q: string; a: string }[]; heading?: string; }
const { faqs, heading = 'Frequently asked questions' } = Astro.props as Props;
---
{faqs.length > 0 && (
  <section class="mt-16">
    <h2 class="text-2xl md:text-3xl font-bold mb-6 text-soil-900">{heading}</h2>
    <div class="divide-y divide-slate-200 border border-slate-200 rounded-lg bg-white">
      {faqs.map((f) => (
        <details class="group p-5">
          <summary class="cursor-pointer list-none flex justify-between items-center font-semibold text-soil-900">
            <span>{f.q}</span>
            <span class="text-grass-700 transition group-open:rotate-45 text-xl leading-none">+</span>
          </summary>
          <div class="mt-3 text-slate-700 leading-relaxed" set:html={f.a} />
        </details>
      ))}
    </div>
  </section>
)}
