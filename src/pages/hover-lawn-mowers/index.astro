---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import PickCard from '../../components/PickCard.astro';
import { articleSchema, breadcrumbSchema, faqSchema, itemListSchema } from '../../lib/schema';

const title = 'Best Hover Lawn Mowers UK 2026 — Banks, Slopes & Rough Grass';
const description = 'Independent UK reviews of the best hover lawn mowers. Float-on-air mowers tested for slopes, banks and rough grass. Flymo, McCulloch, Allett ranked.';
const path = '/hover-lawn-mowers/';
const datePublished = '2026-05-10';

const crumbs = [{ name: 'Home', url: '/' }, { name: 'Hover lawn mowers', url: path }];

const picks = [
  { rank: 1, name: 'Flymo Hovervac 250', brand: 'Flymo', bestFor: 'small lawns and steep banks', rating: 4.5, rrp: '£99', reviewUrl: '/reviews/flymo-hovervac-250-review/', pros: ['Properly floats — useless on flat lawns, brilliant on slopes', 'Light at 6.6 kg', 'Includes 20 L grass collection bag'], cons: ['Cable management same as any corded', 'Stripeless'], verdict: 'The Hovervac is the default UK hover mower. £99, glides over uneven ground that wheel mowers stall on, and the 20 L collection bag means you actually pick up clippings (most hover mowers don\'t). Best on small lawns under 200 m² with awkward levels or a steep bank.' },
  { rank: 2, name: 'Flymo EasiGlide 300', brand: 'Flymo', bestFor: 'classic hover with collection', rating: 4.3, rrp: '£139', reviewUrl: '/reviews/flymo-easi-glide-300-review/', pros: ['30 cm cutting width', 'Folds flat for storage', 'Genuinely floats'], cons: ['Plastic deck flexes', 'Collection bag is small'], verdict: 'The mid-tier Flymo hover. The 30 cm deck cuts more than the 250, the fold-flat handle saves shed space, and at £139 it sits in a sweet spot for anyone whose entire lawn is a slope.' },
  { rank: 3, name: 'Flymo Ultraglide', brand: 'Flymo', bestFor: 'bigger lawns with awkward levels', rating: 4.4, rrp: '£189', reviewUrl: '/reviews/flymo-ultraglide-review/', pros: ['37 cm cutting width', '40 L collection bag', 'Powerful 1,800 W motor'], cons: ['Heavier — feels less floaty than the 250', 'Deck width on the limit of what hover comfortably handles'], verdict: 'The biggest practical hover mower. At a 37 cm deck the lift effect starts to fade compared to the 250, but if you have a large sloped or undulating lawn this is the hover to buy.' },
  { rank: 4, name: 'McCulloch MHT 5622', brand: 'McCulloch', bestFor: 'petrol hover (rare category)', rating: 4.2, rrp: '£329', reviewUrl: '/reviews/mcculloch-mht-5622/', pros: ['Petrol — no cable on a bank', '56 cm cutting width', 'Honda-clone OHV engine'], cons: ['Heavier than electric hovers', 'Niche product, fewer dealers'], verdict: 'Petrol hover mowers are a tiny category — McCulloch and a couple of Atco models. If you have a steep bank that is too far from a power socket and too dangerous for a wheel mower, this is one of the few sensible options.' },
  { rank: 5, name: 'Allett C20 Cylinder Mower', brand: 'Allett', bestFor: 'cylinder cut on slopes', rating: 4.5, rrp: '£549', reviewUrl: '/reviews/allett-c20/', pros: ['Cylinder cut — finest finish on this page', 'Hand-built in Stafford', 'Steel chassis'], cons: ['Not technically hover, but works similarly on small lawns', 'Pricey for a small mower'], verdict: 'Strictly speaking the Allett C20 is a cylinder mower, not a hover, but it\'s the closest you can get to bowling-green finish on a small UK lawn. We include it here because the buyer profile overlaps — owners of small, awkward, perfectionist lawns.' },
];

const faqs = [
  { q: 'What is a hover lawn mower?', a: 'A hover lawn mower has no wheels — instead the spinning blade and a fan produce a cushion of air under the deck that lifts the mower a few millimetres above the lawn. You glide it side-to-side rather than rolling it forward and back. Invented by Karsten Solheim and commercialised in the UK by Flymo in 1965.' },
  { q: 'When is a hover mower the right choice?', a: 'Three situations: (1) steep banks and slopes where a wheeled mower would slide, (2) very rough or uneven lawns where wheels catch on lumps, (3) small awkward lawns with lots of corners where the side-to-side motion is faster than turning a wheeled mower. For a flat, conventional lawn, a hover is slower and the cut is poorer than a wheeled mower.' },
  { q: 'Do hover mowers leave stripes?', a: 'No. Hover mowers have no rear roller, so they leave a uniform untidy cut. If stripes are non-negotiable, look at <a href="/cordless-lawn-mowers/with-roller/">cordless mowers with a rear roller</a> or a petrol Hayter Harrier.' },
  { q: 'Do hover mowers collect grass?', a: 'Some do, some don\'t. The Flymo Hovervac 250, EasiGlide 300 and Ultraglide all have collection bags. The cheaper "mulch only" hover mowers throw clippings sideways onto the lawn. If you have a small ornamental lawn, get a collection model.' },
  { q: 'Are hover mowers good for steep banks?', a: 'Yes — they are usually the only sensible option. A wheeled mower on a slope above 25% slides downhill if you slip; a hover mower is light enough to lift back up. Always cut across the slope (not up and down) and never use one in wet conditions on a steep bank.' },
  { q: 'Are hover mowers all electric?', a: 'Almost all. The cordless and petrol hover categories are tiny — a couple of McCulloch petrols, the new Mountfield HP 41 LI cordless, and a handful of niche models. The mainstream UK hover market is corded electric Flymo.' },
  { q: 'How long does a hover mower last?', a: 'Flymo and similar plastic-deck hover mowers last 8–12 years of typical UK domestic use. The bearings in the fan/motor unit are usually the first thing to fail. Replacement is rarely cost-effective at £100 RRP.' },
  { q: 'Can a hover mower handle long grass?', a: 'Better than most cordless mowers and worse than petrol. The high blade tip speed cuts long grass cleanly but the floating action means the cut height is less precise — you can scalp uneven lawns. Raise the cut height and do two passes.' },
];

const schema = [
  breadcrumbSchema(crumbs),
  articleSchema({ headline: title, description, url: path, datePublished }),
  faqSchema(faqs),
  itemListSchema({ name: 'Best hover lawn mowers UK 2026', url: path, items: picks.map((p, i) => ({ position: i+1, name: p.name, url: p.reviewUrl })) }),
].filter(Boolean);
---
<BaseLayout {title} {description} schema={schema}>
  <article class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />
    <header class="mb-8">
      <p class="text-sm font-semibold text-grass-700 uppercase tracking-wide mb-2">UK Buyer's Guide · Updated May 2026</p>
      <h1 class="text-3xl md:text-5xl font-bold text-soil-900 leading-tight">Best Hover Lawn Mowers UK 2026</h1>
      <p class="mt-4 text-lg text-slate-700 leading-relaxed">
        Hover mowers exist to answer one very specific question: how do I cut a steep bank, a rough lawn, or an awkward little garden where a wheeled mower keeps catching on lumps and dips? They were invented in the UK back in the 1960s, and Flymo still dominates the category sixty years later. Here are the five we recommend without hesitation — yes, most of them are Flymos. The rivals just haven't caught up. Sorry.
      </p>
      <p class="mt-3 text-sm text-slate-500">Independent · No manufacturer paid for placement · We may earn a commission on qualifying purchases.</p>
    </header>

    <img
      src="/images/wp/electric_hover_lawn_mower-1.jpg"
      alt="Flymo hover mower cutting around garden edges"
      width="900" height="506"
      class="w-full rounded-xl mb-10 object-cover"
      loading="eager"
    />

    <aside class="bg-grass-50 border-l-4 border-grass-700 rounded-r-lg p-5 mb-12">
      <h2 class="text-xl font-bold text-soil-900 mb-3">Our top three at a glance</h2>
      <ul class="space-y-2 text-slate-800">
        <li><strong>Best overall:</strong> <a href="/reviews/flymo-hovervac-250-review/" class="text-grass-700 underline">Flymo Hovervac 250</a> — the £99 default UK hover</li>
        <li><strong>Best for bigger banks:</strong> <a href="/reviews/flymo-ultraglide-review/" class="text-grass-700 underline">Flymo Ultraglide</a> — 37 cm cut</li>
        <li><strong>Best petrol:</strong> <a href="/reviews/mcculloch-mht-5622/" class="text-grass-700 underline">McCulloch MHT 5622</a> — for far-from-mains banks</li>
      </ul>
    </aside>

    <div class="prose-mowers">
      <h2 id="what-is">What is a hover lawn mower?</h2>
      <p>
        No wheels. That's the whole trick. A fan attached to the spinning blade kicks up a cushion of air under the deck that lifts the whole mower a few millimetres off the grass — like a tiny lawn-mower-shaped hovercraft. Instead of rolling it forward and back, you glide it side-to-side. End result: a mower that floats over uneven ground and works on slopes a wheeled mower would slide straight down.
      </p>
      <p>
        Funny story — the UK basically invented this category. Karsten Solheim filed the patent in the US in the 1960s (he later went on to invent Ping golf clubs, oddly enough), but it was Flymo who actually got hover mowers into British gardens in 1965. Bright orange, plastic deck, mains-powered. The basic design has barely changed in sixty years. Why mess with what works?
      </p>

      <h2 id="when">When does a hover mower make sense?</h2>
      <p>
        Hover mowers are not all-purpose mowers. They are the right answer in three specific situations:
      </p>
      <ul>
        <li><strong>Steep banks and slopes</strong> — anything over 25% gradient where a wheeled mower would slide</li>
        <li><strong>Rough or uneven lawns</strong> — fields, paddocks, neglected gardens with lumps and dips</li>
        <li><strong>Awkward small gardens</strong> — lots of corners, narrow strips, raised beds — where the side-to-side motion is faster than turning a wheeled mower</li>
      </ul>
      <p>
        For a flat, conventional lawn, a wheeled mower will do a better, faster, more even job. Don\'t buy a hover for a normal back garden.
      </p>

      <h2 id="best-hover">Best hover lawn mowers for 2026</h2>
      <div class="space-y-6 mt-6">{picks.map((p) => <PickCard {...p} />)}</div>

      <h2 id="buying">What to look for</h2>
      <h3>Cutting width</h3>
      <p>25–30 cm hover mowers float properly. 35–40 cm models start to feel heavy and lose the lift advantage on uneven ground. There is a reason Flymo\'s bestsellers are 25–30 cm.</p>
      <h3>Collection or no collection?</h3>
      <p>If your lawn is ornamental, get a model with a grass bag (Hovervac 250, EasiGlide 300, Ultraglide). If it\'s a paddock or a bank you don\'t care about clippings on, the cheaper bag-less mulching hovers are fine.</p>
      <h3>Cable</h3>
      <p>Almost all hover mowers are corded mains. Get a 25 m or 50 m RCD-protected outdoor extension reel. Drape the cable over your shoulder so it doesn\'t get caught — hover mowers love cable.</p>
      <h3>Petrol or cordless hover?</h3>
      <p>Both exist but the categories are tiny. McCulloch makes the only mainstream petrol hover; Mountfield introduced a cordless hover in 2024. For a slope far from any socket, the petrol hover is the practical answer.</p>

      <h2 id="brands">Brands worth shortlisting</h2>
      <ul>
        <li><strong><a href="/brands/flymo/">Flymo</a></strong> — owns the category. 80% of UK hover mowers are Flymos.</li>
        <li><strong>McCulloch</strong> — petrol hovers, niche but real.</li>
        <li><strong><a href="/brands/mountfield/">Mountfield</a></strong> — entered cordless hover in 2024 with the HP 41 LI.</li>
        <li><strong>Atco</strong> — premium British, makes a small range of hover mowers.</li>
        <li><strong>Allett</strong> — cylinder mowers — different category but similar buyer profile (small, awkward, perfectionist lawns).</li>
      </ul>

      <h2 id="related">Related guides</h2>
      <ul>
        <li><a href="/electric-lawn-mowers/">Best electric lawn mowers</a> — for flat small lawns</li>
        <li><a href="/petrol-lawn-mowers/">Best petrol lawn mowers</a> — for bigger gardens</li>
        <li><a href="/advice/garden-size/">Lawn mowers by garden size</a></li>
        <li><a href="/advice/safety-legal/">Lawn mower safety on slopes</a></li>
      </ul>
    </div>
    <FAQ {faqs} />
  </article>
</BaseLayout>
