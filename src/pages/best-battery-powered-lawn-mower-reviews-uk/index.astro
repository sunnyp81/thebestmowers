---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import PickCard from '../../components/PickCard.astro';
import Disclosure from '../../components/Disclosure.astro';
import HowWeResearch from '../../components/HowWeResearch.astro';
import { articleSchema, breadcrumbSchema, faqSchema, itemListSchema } from '../../lib/schema';
import { amazonSearch } from '../../lib/affiliate';

const title = 'Best Cordless & Battery Lawn Mowers UK 2026 - Ranked & Compared';
const description = 'The best cordless and battery lawn mowers for UK gardens in 2026. Nine picks compared on voltage, cutting width, battery, runtime, weight and price - with honest pros, cons and who each is for.';
const path = '/best-battery-powered-lawn-mower-reviews-uk/';
const datePublished = '2024-06-01';
const dateModified = '2026-06-04';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Cordless lawn mowers', url: '/cordless-lawn-mowers/' },
  { name: 'Best battery mowers 2026', url: path },
];

// Curated from manufacturer specifications, verified owner reviews and UK retail pricing.
// Runtime figures are manufacturer claims unless stated; real runtime depends on grass and cut height.
const picks = [
  {
    rank: 1, name: 'EGO Power+ LM2122E-SP', brand: 'EGO',
    bestFor: 'large gardens (500-800 m²)', rating: 4.7, rrp: '£550-£650',
    voltage: '56 V', cut: '52 cm', battery: '1× 5.0 Ah', runtime: 'up to ~45 min claimed', weight: '~24 kg',
    reviewUrl: '/reviews/ego-lm2122e-sp/', affiliateUrl: '',
    image: '/images/cordless_lawn_mower_innovation.webp',
    pros: ['56 V delivers genuinely petrol-like power', 'Variable-speed self-propelled drive', 'IPX4 weather-resistant; folds flat for storage'],
    cons: ['Expensive', 'Soft stripes vs a rear-roller mower'],
    verdict: 'The closest a cordless mower gets to the feel of a petrol self-propelled. The 56 V motor powers through long, damp grass that smaller batteries stall on, and the variable-speed drive makes a 600 m² lawn easy work. If your garden is over 400 m² and you want to ditch petrol, this is the one to beat.',
  },
  {
    rank: 2, name: 'Bosch UniversalRotak 36-550', brand: 'Bosch',
    bestFor: 'best value, medium gardens to 400 m²', rating: 4.5, rrp: '£280-£340',
    voltage: '36 V', cut: '40 cm', battery: '1× 4.0 Ah (Power for All)', runtime: 'covers ~300 m² per charge', weight: '~14 kg',
    reviewUrl: '/reviews/bosch-easyrotak-36-550-lawnmower/', affiliateUrl: '',
    image: '/images/bosch_lawnmower_review_details.webp',
    pros: ['Quiet ProSilence motor', '36 V Power for All battery shared across Bosch garden tools', '50 L grass box is huge for the class'],
    cons: ['Plastic deck flexes on rough ground', 'Heavier than a compact 18 V mower'],
    verdict: 'If you already own Bosch garden kit, the shared 36 V Power for All battery makes the UniversalRotak the obvious pick - one battery runs the hedge trimmer, blower and strimmer too. The 50 L box and 40 cm deck are class-leading under £350.',
  },
  {
    rank: 3, name: 'Gtech CLM 2.0', brand: 'Gtech',
    bestFor: 'small to medium gardens, ease of use', rating: 4.6, rrp: '£230-£270',
    voltage: '36 V', cut: '33 cm', battery: '1× integrated Li-ion', runtime: 'covers ~200 m² per charge', weight: '~12 kg',
    reviewUrl: '/reviews/gtech-clm50/', affiliateUrl: '',
    image: '/images/compact_cordless_easy_storage.webp',
    pros: ['Light enough to carry one-handed', 'Rear roller leaves real stripes', 'Simple, foolproof to live with'],
    cons: ['No mulching plug in the box', 'Pricey vs supermarket brands'],
    verdict: 'The cordless we recommend most to first-time buyers. It cuts cleanly, the rear roller stripes a typical British lawn, and it covers a 200 m² garden on a charge with room to spare. The 33 cm deck means a longer mow on anything over 350 m².',
  },
  {
    rank: 4, name: 'Makita DLM382 (2× 18V LXT)', brand: 'Makita',
    bestFor: 'Makita LXT tool owners', rating: 4.5, rrp: '£250-£330 (bare ~£200)',
    voltage: '36 V (2× 18 V)', cut: '38 cm', battery: '2× 5.0 Ah LXT', runtime: 'covers ~400 m² per charge', weight: '~17 kg',
    reviewUrl: '/brands/makita/', affiliateUrl: '',
    image: '/images/cordless_lawn_mower_details.webp',
    pros: ['Runs on two standard 18 V LXT packs you may already own', 'Brushless motor, trade-grade build', 'Twin-port keeps cutting when one pack drains'],
    cons: ['Bare tool only at the best prices', 'No self-propelled option'],
    verdict: 'For the huge number of UK households with Makita LXT drills and drivers, the DLM382 is the cheapest route to a serious 38 cm cordless - buy bare and add the batteries you own. Brushless, well built, and quietly one of the best-value picks if the ecosystem fits.',
  },
  {
    rank: 5, name: 'Ryobi RY18LMX40A-150', brand: 'Ryobi',
    bestFor: 'Ryobi ONE+ owners on a budget', rating: 4.4, rrp: '£220-£290 (with battery)',
    voltage: '18 V', cut: '40 cm', battery: '1× 5.0 Ah ONE+', runtime: 'covers ~250 m² per charge', weight: '~16 kg',
    reviewUrl: '/reviews/ryobi-cordless/', affiliateUrl: '',
    image: '/images/battery_powered_ryobi_lawnmower_review.webp',
    pros: ['Slots into the 18 V ONE+ ecosystem (200+ tools)', 'Self-propelled drive on this model', 'Brushless motor for a long life'],
    cons: ['Single 18 V pack works hard on damp grass', 'Cut-height lever is fiddly'],
    verdict: 'If you already own a Ryobi drill or strimmer, the RY18LMX40A is the cheapest sensible cordless going - buy bare-tool and you are under £160 for a real 40 cm self-propelled deck. Not the most powerful here, but on a dry, regularly mown lawn it is more than enough.',
  },
  {
    rank: 6, name: 'Mountfield Princess 34 Li-48', brand: 'Mountfield',
    bestFor: 'classic stripes on a small lawn', rating: 4.3, rrp: '£350-£420',
    voltage: '48 V', cut: '34 cm', battery: '1× 4.0 Ah', runtime: 'covers ~250 m² per charge', weight: '~17 kg',
    reviewUrl: '/reviews/mountfield-princess-34/', affiliateUrl: '',
    image: '/images/cordless_lawnmower_with_battery-3.webp',
    pros: ['Steel deck feels solid', 'True rear roller for sharp stripes', '48 V system with decent torque'],
    cons: ['Only a 34 cm cut', 'Battery sold separately at some retailers'],
    verdict: 'A proper Italian-built striping mower for a fraction of a petrol Princess. If you care about stripes more than acreage, this is the cheapest way to get them from a battery mower with a metal deck.',
  },
  {
    rank: 7, name: 'Greenworks GD40LM45', brand: 'Greenworks',
    bestFor: 'large gardens on a budget', rating: 4.2, rrp: '£250-£330',
    voltage: '40 V', cut: '45 cm', battery: '1× 4.0-6.0 Ah', runtime: 'covers ~450 m² per charge', weight: '~20 kg',
    reviewUrl: '/brands/greenworks/', affiliateUrl: '',
    image: '/images/cordless_lawn_mower_convenience-1.webp',
    pros: ['Big 45 cm deck for the money', '40 V platform shared across Greenworks garden range', 'Good value with a larger 6.0 Ah pack'],
    cons: ['Build is functional rather than premium', 'Heavier to manoeuvre in tight spots'],
    verdict: 'The widest cordless deck you can get near the £300 mark. If you have a 400-600 m² lawn and do not want to spend EGO money, the Greenworks 40 V covers a lot of grass per charge - pair it with the 6.0 Ah battery for the best results.',
  },
  {
    rank: 8, name: 'WORX WG730E (2× 20V PowerShare)', brand: 'WORX',
    bestFor: 'budget twin-battery convenience', rating: 4.1, rrp: '£180-£240',
    voltage: '40 V (2× 20 V)', cut: '34 cm', battery: '2× 4.0 Ah', runtime: 'covers ~300 m² per charge', weight: '~17 kg',
    reviewUrl: '/brands/worx/', affiliateUrl: '',
    image: '/images/cordless_lawn_mower_details.webp',
    pros: ['Two batteries included at a low price', 'PowerShare packs run other WORX tools', 'Intellicut dial trades power for runtime'],
    cons: ['34 cm deck is modest for the weight', 'No self-propelled drive'],
    verdict: 'A lot of cordless for the money - twin 20 V packs in the box means no second purchase to get going. Best for a tidy 200-300 m² lawn where value matters more than a wide deck or stripes.',
  },
  {
    rank: 9, name: 'Bosch CityMower 18V-32-300', brand: 'Bosch',
    bestFor: 'small gardens under 200 m²', rating: 4.4, rrp: '£150-£190',
    voltage: '18 V', cut: '32 cm', battery: '1× 4.0 Ah (Power for All)', runtime: 'covers ~150 m² per charge', weight: '~10 kg',
    reviewUrl: '/reviews/bosch-rotak-32-review/', affiliateUrl: '',
    image: '/images/compact_cordless_easy_storage.webp',
    pros: ['Very light - easy to lift and store', 'Shares the 18 V Power for All battery', 'Cheapest way into a quality brand platform'],
    cons: ['32 cm deck is small for over 200 m²', 'Modest 31 L grass box'],
    verdict: 'The best small-garden battery mower under £200. Light, quiet, simple, and it shares the 18 V Power for All pack with Bosch drills and trimmers. For a courtyard or front lawn, you do not need more.',
  },
];

const faqs = [
  { q: 'What is the best cordless lawn mower in the UK for 2026?', a: 'For most UK gardens the <a href="/reviews/bosch-easyrotak-36-550-lawnmower/">Bosch UniversalRotak 36-550</a> is the best all-round value, while the <a href="/reviews/ego-lm2122e-sp/">EGO LM2122E-SP</a> is the top pick for large gardens over 400&nbsp;m². The right mower depends mostly on lawn size and whether you already own a battery platform.' },
  { q: 'Is "cordless" the same as a "battery" lawn mower?', a: 'Yes. UK retailers use both terms for the same thing: a rechargeable lithium-ion mower with no power lead and no petrol engine. "Cordless lawn mower" is the older phrase, "battery lawn mower" the newer one.' },
  { q: 'How big a garden can a battery lawn mower handle?', a: 'A single 18&nbsp;V mower (4.0&nbsp;Ah) typically covers 150-250&nbsp;m² per charge. A 36-40&nbsp;V mower covers 300-500&nbsp;m². Twin-battery 36-56&nbsp;V machines reach 600-1000&nbsp;m². Over 1000&nbsp;m², buy a spare battery or consider <a href="/petrol-lawn-mowers/">petrol</a> or a <a href="/robot-lawn-mowers/">robot mower</a>.' },
  { q: 'What battery voltage do I need?', a: 'Under 200&nbsp;m²: 18&nbsp;V or 24&nbsp;V is fine. 200-400&nbsp;m²: aim for 36&nbsp;V. Larger or rough, damp lawns: 40&nbsp;V, 48&nbsp;V or 56&nbsp;V. Voltage drives torque - higher voltage stops the blade bogging down in long wet grass. See our <a href="/buying-guide/cordless-vs-petrol-vs-electric/">voltage explainer</a>.' },
  { q: 'Do battery lawn mowers leave stripes?', a: 'Only models with a rear roller, such as the Gtech CLM 2.0 or Mountfield Princess 34. Most cordless mowers under £250 use rear wheels and leave no stripe. If stripes matter, look at our <a href="/cordless-lawn-mowers/with-roller/">cordless mowers with a roller</a> guide.' },
  { q: 'How long do cordless mower batteries last before replacement?', a: 'A quality lithium-ion pack (Bosch, Makita, EGO, Ryobi, DeWalt) is rated for roughly 500-1000 charge cycles - about 5-8 years for a typical UK gardener mowing 25-30 times a year. Cheap own-brand cells often fade after 2-3 seasons.' },
  { q: 'Are the prices on this page accurate?', a: 'We show typical UK price bands, not live prices - mower prices move constantly with deals and stock. Always check the current price on the retailer page before buying; the "Check price on Amazon" buttons go straight to the live listing.' },
];

const schema = [
  breadcrumbSchema(crumbs),
  articleSchema({ headline: title, description, url: path, datePublished, dateModified, image: '/images/cordless_lawn_mower_convenience-1.webp' }),
  faqSchema(faqs),
  itemListSchema({
    name: 'Best cordless & battery lawn mowers UK 2026',
    url: path,
    items: picks.map((p, i) => ({ position: i + 1, name: p.name, url: p.reviewUrl })),
  }),
].filter(Boolean);
---
<BaseLayout {title} {description} schema={schema} ogImage="/images/cordless_lawn_mower_convenience-1.webp">
  <article class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />

    <header class="mb-6">
      <p class="text-sm font-semibold text-grass-700 uppercase tracking-wide mb-2">UK Buyer's Guide · Updated June 2026</p>
      <h1 class="text-3xl md:text-5xl font-bold text-soil-900 leading-tight">Best Cordless &amp; Battery Lawn Mowers UK 2026</h1>
      <p class="mt-4 text-lg text-slate-700 leading-relaxed">
        Cordless has quietly become the default mower for British gardens. For anything under about 600&nbsp;m², a good battery mower now out-cuts a cheap petrol one: quieter, lighter, push-button start, no fuel or servicing. Below are the nine cordless and battery lawn mowers we rate most highly for 2026, compared on the specs that actually matter - voltage, cutting width, battery, runtime, weight and price - and ranked by who each one is for.
      </p>
    </header>

    <Disclosure />

    <img
      src="/images/cordless_lawn_mower_convenience-1.webp"
      alt="Cordless battery lawn mower cutting a UK garden lawn"
      width="900" height="506"
      class="w-full rounded-xl my-6 object-cover"
      loading="eager" fetchpriority="high"
    />

    <!-- Quick verdict -->
    <aside class="bg-grass-50 border-l-4 border-grass-700 rounded-r-lg p-5 mb-10">
      <h2 class="text-xl font-bold text-soil-900 mb-3">Our top picks at a glance</h2>
      <ul class="space-y-2 text-slate-800">
        <li><strong>Best overall for big lawns:</strong> <a href="/reviews/ego-lm2122e-sp/" class="text-grass-700 underline">EGO Power+ LM2122E-SP</a> - petrol-equivalent 56&nbsp;V power</li>
        <li><strong>Best value:</strong> <a href="/reviews/bosch-easyrotak-36-550-lawnmower/" class="text-grass-700 underline">Bosch UniversalRotak 36-550</a> - huge box, shared battery platform</li>
        <li><strong>Best for small gardens:</strong> <a href="/reviews/bosch-rotak-32-review/" class="text-grass-700 underline">Bosch CityMower 18V-32</a> - light, simple, under £200</li>
        <li><strong>Best for stripes:</strong> <a href="/reviews/mountfield-princess-34/" class="text-grass-700 underline">Mountfield Princess 34 Li-48</a> - steel deck, rear roller</li>
      </ul>
    </aside>

    <!-- Comparison table -->
    <section class="prose-mowers">
      <h2 id="compare">Cordless lawn mowers compared</h2>
      <p>Every pick at a glance. Runtime figures are manufacturer estimates or our coverage guide for a typical dry UK lawn - real runtime varies with grass length, dampness and cut height. Prices are typical UK bands, not live prices.</p>
      <table>
        <thead>
          <tr><th>Mower</th><th>Best for</th><th>Voltage</th><th>Cut width</th><th>Battery</th><th>Runtime / coverage</th><th>Weight</th><th>Price band</th></tr>
        </thead>
        <tbody>
          {picks.map((p) => (
            <tr>
              <td><a href={p.reviewUrl}>{p.name}</a></td>
              <td>{p.bestFor}</td>
              <td>{p.voltage}</td>
              <td>{p.cut}</td>
              <td>{p.battery}</td>
              <td>{p.runtime}</td>
              <td>{p.weight}</td>
              <td>{p.rrp}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <HowWeResearch heading="How we chose these mowers" />

    <section class="prose-mowers">
      <h2 id="reviews">The nine best cordless &amp; battery lawn mowers</h2>
      <p>Ranked by who we would buy each one for. Tap any pick to read the full review, or "Check price on Amazon" for the live UK price.</p>
    </section>
    <div class="space-y-6 mt-6">
      {picks.map((p) => <PickCard {...p} affiliateUrl={amazonSearch(p.name + ' lawn mower')} />)}
    </div>

    <section class="prose-mowers">
      <h2 id="choose">How to choose: the five specs that matter</h2>

      <h3>1. Match cutting width to your lawn</h3>
      <p>The cutting width is how wide a strip the blade clears per pass - wider finishes faster but is heavier to steer. Rough guide: <strong>30-34&nbsp;cm</strong> for gardens under 150&nbsp;m², <strong>36-40&nbsp;cm</strong> for a typical 150-400&nbsp;m² semi, <strong>41-46&nbsp;cm</strong> for 400-800&nbsp;m², and <strong>48&nbsp;cm+</strong> (usually twin-battery, self-propelled) for the largest lawns.</p>

      <h3>2. Voltage drives torque</h3>
      <p>The bigger the battery number - 18&nbsp;V, 36&nbsp;V, 40&nbsp;V, 56&nbsp;V - the more torque the motor delivers, and torque is what stops a mower stalling in long, damp grass. A weekly-mown front lawn is happy on 18&nbsp;V; a back lawn that goes feral over a holiday wants 36&nbsp;V or more. Our <a href="/buying-guide/cordless-vs-petrol-vs-electric/">buying guide</a> explains voltage, runtime and brushless motors in full.</p>

      <h3>3. Battery: single, twin, and brushless</h3>
      <p>Single-battery mowers are lighter and cheaper; twin-battery models double the runtime for roughly £100 more and suit lawns over 500&nbsp;m². Almost every mower here uses a <strong>brushless motor</strong> - quieter, more efficient and longer-lived than the brushed motors in cheap supermarket mowers. Crucially, the battery is a platform decision: a Bosch, Ryobi or Makita pack also runs that brand's hedge trimmer, blower and strimmer.</p>

      <h3>4. Self-propelled or push?</h3>
      <p>Self-propelled mowers drive their own wheels so you steer rather than shove - worth the £80-£150 premium on a slope, on lawns over 400&nbsp;m², or if a 20&nbsp;kg push is uncomfortable. For a flat lawn under 200&nbsp;m², a push mower is lighter, cheaper and simpler.</p>

      <h3>5. Weight and stripes</h3>
      <p>Manufacturer weights often omit the battery; budget 1-2&nbsp;kg more than the spec sheet, and knock 5&nbsp;kg off your limit if you lift the mower over a step each week. For the classic striped finish you need a <a href="/cordless-lawn-mowers/with-roller/">rear-roller mower</a> - wheeled mowers leave no stripe.</p>

      <h2 id="by-garden">Find the right mower for your garden</h2>
      <ul>
        <li><a href="/cordless-lawn-mowers/small-gardens/">Best cordless mowers for small gardens</a></li>
        <li><a href="/cordless-lawn-mowers/large-gardens/">Best cordless mowers for large gardens</a></li>
        <li><a href="/cordless-lawn-mowers/under-200/">Best budget cordless mowers under £200</a></li>
        <li><a href="/cordless-lawn-mowers/self-propelled/">Best self-propelled cordless mowers</a></li>
        <li><a href="/cordless-lawn-mowers/with-roller/">Cordless mowers with a roller (for stripes)</a></li>
      </ul>

      <h2 id="brands">Cordless mowers by brand</h2>
      <p>Cordless is as much a battery-platform choice as a mower choice. If you already own one of these systems, your shortlist gets short fast:</p>
      <ul>
        <li><strong><a href="/brands/bosch/">Bosch</a></strong> - 18&nbsp;V and 36&nbsp;V Power for All, the most cross-compatible mainstream UK platform</li>
        <li><strong><a href="/brands/ego/">EGO</a></strong> - 56&nbsp;V Arc Lithium, the closest cordless gets to petrol</li>
        <li><strong><a href="/brands/makita/">Makita</a></strong> - 18&nbsp;V LXT and 40&nbsp;V XGT, trade-grade build</li>
        <li><strong><a href="/brands/ryobi/">Ryobi</a></strong> - 18&nbsp;V ONE+, over 200 compatible tools</li>
        <li><strong><a href="/brands/gtech/">Gtech</a></strong> - light, simple, single-platform</li>
        <li><strong><a href="/brands/greenworks/">Greenworks</a></strong> - 40&nbsp;V value, wide decks for the money</li>
        <li><strong><a href="/brands/flymo/">Flymo</a></strong> - compact, affordable, easy-store</li>
        <li><strong><a href="/brands/worx/">WORX</a></strong> - 20&nbsp;V PowerShare twin-battery value</li>
      </ul>

      <h2 id="related">Related guides</h2>
      <ul>
        <li><a href="/buying-guide/cordless-vs-petrol-vs-electric/">Cordless vs petrol vs electric - which should you buy?</a></li>
        <li><a href="/advice/maintenance/sharpen-blade/">How to sharpen a lawn mower blade</a></li>
        <li><a href="/advice/maintenance/battery-care/">Cordless mower battery care &amp; runtime</a></li>
        <li><a href="/advice/mowing-wet-grass/">Can you mow wet grass?</a></li>
      </ul>
    </section>

    <FAQ {faqs} />
  </article>
</BaseLayout>
