---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { breadcrumbSchema } from '../../lib/schema';

const title = 'Privacy Policy — The Best Mowers';
const description = 'Privacy policy for thebestmowers.co.uk. How we handle your data, cookies and third-party services.';
const path = '/privacy/';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Privacy policy', url: path },
];

const schema = [breadcrumbSchema(crumbs)];
---
<BaseLayout {title} {description} {schema}>
  <article class="max-w-3xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />
    <h1 class="text-3xl md:text-5xl font-bold text-soil-900 leading-tight mb-6">Privacy Policy</h1>
    <div class="prose-mowers">
      <p>Last updated: May 2026.</p>
      <h2>Who we are</h2>
      <p>The Best Mowers (thebestmowers.co.uk) is an independent UK lawn mower review site. We don't sell products directly — we link to retailers who do.</p>
      <h2>What data we collect</h2>
      <p>We don't collect personal data through forms or accounts. We use privacy-respecting analytics to understand which pages are useful. No personally identifiable information is stored.</p>
      <h2>Cookies</h2>
      <p>We use essential cookies only. Third-party retailers (Amazon, Screwfix, etc.) may set their own cookies when you click affiliate links — their privacy policies apply.</p>
      <h2>Affiliate links</h2>
      <p>We earn commissions when you buy through our links. This doesn't affect the price you pay. Affiliate relationships are disclosed on every page containing product links.</p>
      <h2>Third-party services</h2>
      <p>We may use Cloudflare for hosting and performance. Cloudflare's privacy policy applies to infrastructure-level data processing.</p>
      <h2>Your rights</h2>
      <p>Under UK GDPR, you have the right to access, rectify or delete any personal data we hold. Contact us at <a href="mailto:hello@thebestmowers.co.uk">hello@thebestmowers.co.uk</a>.</p>
    </div>
  </article>
</BaseLayout>
