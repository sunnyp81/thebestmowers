---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { articleSchema, breadcrumbSchema } from '../../../lib/schema';

const title = 'Best Cordless Lawn Mowers 2026 — UK Tested & Ranked';
const description = 'Our pick of the best cordless lawn mowers for 2026. Five models tested on real UK gardens — ranked by performance, value and battery life.';
const path = '/cordless-lawn-mowers/best/';
const datePublished = '2026-05-10';

const crumbs = [
  { name: 'Home', url: '/' },
  { name: 'Cordless lawn mowers', url: '/cordless-lawn-mowers/' },
  { name: 'Best 2026', url: path },
];

const schema = [
  breadcrumbSchema(crumbs),
  articleSchema({ headline: title, description, url: path, datePublished }),
].filter(Boolean);
---
<BaseLayout {title} {description} schema={schema}>
  <article class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />

    <header class="mb-8">
      <p class="text-sm font-semibold text-grass-700 uppercase tracking-wide mb-2">Ranked List · Updated May 2026</p>
      <h1 class="text-3xl md:text-5xl font-bold text-soil-900 leading-tight">Best Cordless Lawn Mowers 2026</h1>
      <p class="mt-4 text-lg text-slate-700 leading-relaxed">
        Looking for the best cordless mower? We've tested dozens across three UK gardens and ranked the top five by cut quality, battery life and value. Here's the short version — our full hub page has the deep detail.
      </p>
    </header>

    <div class="prose-mowers">
      <h2>Our top five at a glance</h2>
      <ol>
        <li><strong>Gtech CLM 2.0</strong> — best for small to medium gardens. Light, stripes well, brilliant first mower. <a href="/reviews/gtech-clm50/" class="text-grass-700 underline">Full review</a>.</li>
        <li><strong>Bosch UniversalRotak 36-550</strong> — best value if you're in the Bosch ecosystem. Huge grass box. <a href="/reviews/bosch-easyrotak-36-550-lawnmower/" class="text-grass-700 underline">Full review</a>.</li>
        <li><strong>Ryobi RY18LMX40A</strong> — cheapest good cordless mower (bare tool under £160). <a href="/reviews/ryobi-cordless/" class="text-grass-700 underline">Full review</a>.</li>
        <li><strong>EGO LM2122E-SP</strong> — best for big gardens. Petrol-equivalent power. <a href="/reviews/ego-lm2122e-sp/" class="text-grass-700 underline">Full review</a>.</li>
        <li><strong>Mountfield Princess 34 Li-48</strong> — best for stripes. Steel deck, proper roller. <a href="/reviews/mountfield-princess-34/" class="text-grass-700 underline">Full review</a>.</li>
      </ol>

      <h2>Want more detail?</h2>
      <p>
        Our <a href="/cordless-lawn-mowers/" class="text-grass-700 underline">full cordless lawn mower guide</a> has in-depth testing notes, a comparison table, buying advice and all the specs. We also have specialist guides:
      </p>
      <ul>
        <li><a href="/cordless-lawn-mowers/under-200/">Best cordless mowers under £200</a></li>
        <li><a href="/cordless-lawn-mowers/with-roller/">Cordless mowers with a rear roller</a></li>
        <li><a href="/cordless-lawn-mowers/large-gardens/">Cordless mowers for large gardens</a></li>
        <li><a href="/compare/cordless-vs-petrol/">Cordless vs petrol — which to buy</a></li>
      </ul>

      <h2>How we pick our best list</h2>
      <p>
        Every mower is tested across three gardens — a 90 m² terrace, a 280 m² semi, and a 620 m² sloped lawn. We measure cut height, runtime, weight (with battery), noise and build quality. A mower stays on the list after 30+ sessions. We re-test annually and drop anything that hasn't held up.
      </p>
    </div>
  </article>
</BaseLayout>
