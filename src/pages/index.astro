---
import BaseLayout from '../layouts/BaseLayout.astro';
import HowWeResearch from '../components/HowWeResearch.astro';
import { POWER_TYPE_HUBS, BRAND_HUBS } from '../lib/site';

const title = 'The Best Mowers UK - Independent Lawn Mower Reviews & Buying Guides';
const description = 'Independent, research-led UK lawn mower buying guides. Compare the best cordless, battery, petrol, robot and ride-on mowers from every major brand.';

const featured = [
  { slug: 'cordless-lawn-mowers', label: 'Cordless lawn mowers', tag: 'Most popular', tagline: 'Quiet, light, no fuel - the default choice for UK gardens under 600 m².' },
  { slug: 'robot-lawn-mowers', label: 'Robot lawn mowers', tag: 'Trending 2026', tagline: 'Set them and forget them. Best for medium lawns and time-poor owners.' },
  { slug: 'petrol-lawn-mowers', label: 'Petrol lawn mowers', tag: 'Big lawns', tagline: 'Still the king for anything over 800 m² or rough wet grass.' },
  { slug: 'electric-lawn-mowers', label: 'Electric lawn mowers', tag: 'Budget pick', tagline: 'Corded mains-powered. Cheapest path to a cleanly cut small lawn.' },
  { slug: 'ride-on-lawn-mowers', label: 'Ride-on lawn mowers', tag: 'Acreage', tagline: 'For lawns over 1000 m². The models worth shortlisting, compared.' },
  { slug: 'hover-lawn-mowers', label: 'Hover lawn mowers', tag: 'Slopes & banks', tagline: 'Float-on-air mowers - best for steep banks and rough lawns.' },
];
---
<BaseLayout {title} {description} ogType="website">
  <section class="bg-gradient-to-b from-grass-50 to-white border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 py-16 md:py-24 text-center">
      <p class="text-sm font-semibold text-grass-700 uppercase tracking-wide mb-3">Independent · UK · Research-led</p>
      <h1 class="text-4xl md:text-6xl font-bold text-soil-900 leading-tight">The right lawn mower for your garden</h1>
      <p class="mt-5 text-lg md:text-xl text-slate-700 max-w-2xl mx-auto leading-relaxed">
        Clear, honest UK buying guides built from manufacturer specifications, verified owner reviews and real retail pricing, cross-checked so the figures match the box. No sponsored top-tens, no copy-pasted retailer feeds. We specialise in cordless and battery mowers, the default choice for most British gardens.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/best-battery-powered-lawn-mower-reviews-uk/" class="bg-grass-700 hover:bg-grass-800 text-white font-semibold px-5 py-3 rounded-md min-h-[44px]">Best cordless mowers 2026</a>
        <a href="/buying-guide/cordless-vs-petrol-vs-electric/" class="bg-white border border-slate-300 hover:border-grass-700 text-soil-900 font-semibold px-5 py-3 rounded-md min-h-[44px]">Cordless vs petrol vs electric</a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 pt-12 -mb-4">
    <img
      src="/images/top_lawn_mowers_recommended.webp"
      alt="The best lawn mowers for UK gardens, independently reviewed"
      width="900" height="506"
      class="w-full rounded-2xl object-cover shadow-sm"
      loading="eager" fetchpriority="high"
    />
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-soil-900 mb-8 text-center">Browse by power type</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {featured.map((f) => (
        <a href={`/${f.slug}/`} class="group border border-slate-200 rounded-xl p-6 bg-white hover:border-grass-700 hover:shadow-md transition">
          <span class="inline-block text-xs font-bold text-grass-700 bg-grass-50 px-2 py-1 rounded uppercase tracking-wide mb-3">{f.tag}</span>
          <h3 class="text-xl font-bold text-soil-900 group-hover:text-grass-700 mb-2">{f.label}</h3>
          <p class="text-slate-600 text-sm leading-relaxed">{f.tagline}</p>
          <span class="inline-block mt-4 text-grass-700 font-semibold text-sm">Read the guide →</span>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-slate-50 border-y border-slate-200 py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-soil-900 mb-8 text-center">By brand</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {BRAND_HUBS.map((b) => (
          <a href={`/brands/${b}/`} class="bg-white border border-slate-200 hover:border-grass-700 px-4 py-2 rounded-full text-sm font-medium capitalize">{b.replace('-', ' ')}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="rounded-2xl bg-grass-700 text-white p-8 md:p-12 text-center">
      <p class="text-sm font-semibold uppercase tracking-wide text-grass-100 mb-2">Start here</p>
      <h2 class="text-2xl md:text-4xl font-bold mb-3">Best Cordless &amp; Battery Lawn Mowers UK 2026</h2>
      <p class="text-grass-50 max-w-2xl mx-auto leading-relaxed mb-6">
        Nine cordless mowers compared on voltage, cutting width, battery, runtime, weight and price, ranked by who each one suits. Our most complete guide.
      </p>
      <a href="/best-battery-powered-lawn-mower-reviews-uk/" class="inline-block bg-white text-grass-800 font-semibold px-6 py-3 rounded-md hover:bg-grass-50 min-h-[44px]">Read the guide →</a>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 pb-16">
    <HowWeResearch heading="How we choose" />
  </section>
</BaseLayout>
