---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import PickCard from '../../../components/PickCard.astro';
import { articleSchema, breadcrumbSchema, faqSchema, itemListSchema } from '../../../lib/schema';

const title = 'Einhell Lawn Mowers UK - Power X-Change Range Reviewed';
const description = 'Independent reviews of Einhell lawn mowers. Power X-Change 18V/36V cordless platform that undercuts Bosch by 30% - but how does it compare on the specs and owner reviews?';
const path = '/brands/einhell/';
const datePublished = '2026-05-10';

const crumbs = [{ name: 'Home', url: '/' }, { name: 'Brands', url: '/brands/' }, { name: 'Einhell', url: path }];

const picks = [
  { rank: 1, name: 'Einhell GE-CM 36/37 Li', brand: 'Einhell', bestFor: 'value cordless on Power X-Change', rating: 4.4, rrp: '£289', reviewUrl: '/brands/einhell/', pros: ['Twin-18V Power X-Change', '37 cm deck', 'Mulching plug included'], cons: ['Battery range smaller than Bosch', 'Plastic deck'], verdict: 'A genuinely well-priced cordless mower running on the Einhell Power X-Change platform. 90% of Bosch UniversalRotak performance for 75% of the price - that\'s the Einhell formula in one sentence.' },
  { rank: 2, name: 'Einhell GE-EM 1233 M', brand: 'Einhell', bestFor: 'cheap mulching corded', rating: 4.2, rrp: '£139', reviewUrl: '/reviews/einhell-review/', pros: ['Mulching plug at this price', '33 L grass box', 'Solid Einhell warranty'], cons: ['Plastic deck flexes', 'Handle fold is fiddly'], verdict: 'A budget corded mower that does mulching properly - rare at this price. Owner reviews report it lasting several seasons; build is plastic-y but functional.' },
];

const faqs = [
  { q: 'Is Einhell a good lawn mower brand?', a: 'For the price, yes - Einhell consistently delivers 85-90% of the build quality of Bosch or Makita at 60-75% of the price. The Power X-Change battery platform now has 250+ tools across DIY, garden and household categories. As a brand for the value-conscious DIY-focused buyer, it\'s genuinely strong.' },
  { q: 'What is Power X-Change?', a: 'Einhell\'s shared 18V battery platform - same battery across drills, mowers, hedge trimmers, blowers, vacuum cleaners, lights and much more. Higher-output garden tools (mowers, brushcutters) take twin batteries for 36V output. Over 250 tools now on the platform globally.' },
  { q: 'Where is Einhell based?', a: 'German - founded in 1964 in Landau an der Isar, Bavaria. Modern manufacturing is in China. Einhell is a publicly listed company in Germany and the brand has invested heavily in the Power X-Change platform since 2014.' },
  { q: 'Einhell vs Bosch - which to buy?', a: 'Bosch if you want the slightly better build and a wider UK retailer footprint. Einhell if price matters more and you don\'t mind a slightly less polished user experience. On any direct mower comparison, the Einhell is usually 25-30% cheaper for 90% of the experience. For value buyers, that\'s a clear win.' },
];

const schema = [
  breadcrumbSchema(crumbs),
  articleSchema({ headline: title, description, url: path, datePublished, dateModified: '2026-06-05' }),
  faqSchema(faqs),
  itemListSchema({ name: 'Best Einhell lawn mowers 2026', url: path, items: picks.map((p, i) => ({ position: i+1, name: p.name, url: p.reviewUrl })) }),
];
---
<BaseLayout {title} {description} {schema}>
  <article class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />
    <header class="mb-8">
      <p class="text-sm font-semibold text-grass-700 uppercase tracking-wide mb-2">Brand guide · Updated May 2026</p>
      <h1 class="text-3xl md:text-5xl font-bold text-soil-900 leading-tight">Einhell Lawn Mowers</h1>
      <p class="mt-4 text-lg text-slate-700 leading-relaxed">
        Einhell is the German brand that decided years ago to undercut Bosch on price while keeping 90% of the build quality. The Power X-Change battery platform now has 250+ tools across drills, mowers, hedge trimmers, vacuum cleaners and weirdly even heated blankets. The mowers themselves are honest, value-focused, and consistently the cheapest entry into "actually decent cordless" you can find. Don't expect Bosch polish - but for £100 less per mower, you don't need it.
      </p>
    </header>

    <img
      src="/images/einhell_cordless_lawnmower_details.webp"
      alt="Einhell cordless lawn mower close-up"
      width="900" height="506"
      class="w-full rounded-xl mb-10 object-cover"
      loading="eager"
    />

    <div class="prose-mowers">
      <h2 id="best">Best Einhell lawn mowers</h2>
      <div class="space-y-6 mt-6">{picks.map((p) => <PickCard {...p} />)}</div>

      <h2 id="vs-rivals">Where Einhell fits vs rivals</h2>
      <p>
        Direct rival is <a href="/brands/bosch/">Bosch</a> - same German DIY-and-garden positioning, similar tool count, Einhell consistently cheaper. <a href="/brands/ryobi/">Ryobi</a> is the other value champion with a much wider 280-tool ecosystem. <a href="/brands/worx/">Worx</a> sits at similar pricing but with 80+ tools to Einhell's 250+. For most UK domestic buyers, the realistic shortlist is Bosch vs Einhell vs Ryobi - and the choice comes down to which battery ecosystem you want to invest in.
      </p>

      <h2 id="related">Related guides</h2>
      <ul>
        <li><a href="/cordless-lawn-mowers/">Best cordless lawn mowers</a></li>
        <li><a href="/electric-lawn-mowers/">Best electric corded lawn mowers</a></li>
        <li><a href="/brands/bosch/">Bosch lawn mowers</a></li>
        <li><a href="/brands/ryobi/">Ryobi lawn mowers</a></li>
      </ul>
    </div>
    <FAQ {faqs} />
  </article>
</BaseLayout>
