---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import PickCard from '../../../components/PickCard.astro';
import { articleSchema, breadcrumbSchema, faqSchema, itemListSchema } from '../../../lib/schema';

const title = 'Mountfield Lawn Mowers UK - Petrol, Ride-On & Cordless Reviewed';
const description = 'Independent reviews of Mountfield lawn mowers. Italian-built petrol, ride-on tractors, and the new cordless range - best value in their respective categories.';
const path = '/brands/mountfield/';
const datePublished = '2026-05-10';

const crumbs = [{ name: 'Home', url: '/' }, { name: 'Brands', url: '/brands/' }, { name: 'Mountfield', url: path }];

const picks = [
  { rank: 1, name: 'Mountfield SP46', brand: 'Mountfield', bestFor: 'best value self-propelled petrol', rating: 4.5, rrp: '£329', reviewUrl: '/reviews/mountfield-sp46/', pros: ['Mountfield ST 140 OHV engine', '46 cm steel deck', 'Self-propelled at this price'], cons: ['Single-speed drive', 'Engine warranty shorter than Honda'], verdict: 'The default sub-£400 self-propelled petrol mower in the UK. Italian-built, the ST 140 engine is genuinely reliable, and the 46 cm deck handles 600-800 m² without breaking sweat.' },
  { rank: 2, name: 'Mountfield 1538M-SD', brand: 'Mountfield', bestFor: 'value 1-acre ride-on', rating: 4.5, rrp: '£1,799', reviewUrl: '/reviews/mountfield-1538m-sd/', pros: ['Italian-built ST 175 engine', '98 cm side-discharge deck', '5-position cut height'], cons: ['Side discharge only - no collection', 'Manual transmission'], verdict: 'For half- to one-acre lawns, the cheapest ride-on we trust. Side-discharges into the lawn (no collection bin to empty), the engine is a known-good Mountfield unit.' },
  { rank: 3, name: 'Mountfield Princess 34 Li-48', brand: 'Mountfield', bestFor: 'cordless with classic stripes', rating: 4.3, rrp: '£399', reviewUrl: '/reviews/mountfield-princess-34/', pros: ['Steel deck - feels solid', 'True rear roller for sharp stripes', '48V system'], cons: ['Only 34 cm cut', 'Smaller battery than Bosch rivals'], verdict: 'A proper Italian-built mower at a fraction of the cost of a petrol Princess. The cheapest way into rear-roller stripes from a battery mower with a metal deck.' },
];

const faqs = [
  { q: 'Are Mountfield lawn mowers any good?', a: 'For value, yes - consistently the best price-to-quality ratio in petrol mowers and ride-ons in the UK market. The brand is Italian-owned (under the GGP/Stiga group) and engines are made in Italy. Build quality is honest mid-tier - not Honda or Hayter, but a long way above no-name imports.' },
  { q: 'Where are Mountfield mowers made?', a: 'Mountfield is owned by Stiga SpA in Italy. Engines are manufactured at Stiga\'s plant in Castelfranco Veneto. Mowers are assembled in Italy and Slovakia. Despite the British-sounding name, there has been no UK production for decades.' },
  { q: 'Mountfield SP series vs HP series - what is the difference?', a: 'SP = Self-Propelled. HP = Hand-Propelled (push). The number after is the deck width in cm - SP46 is a 46 cm self-propelled. Larger numbers (SP53, SP56) get bigger and more expensive.' },
  { q: 'Is Mountfield the same as Stiga?', a: 'Same parent company, different brand positioning. Mountfield is the mainstream UK brand sold in B&Q and garden centres. Stiga is the slightly more premium variant sold through specialist dealers. Many models are the same machine with a different sticker.' },
  { q: 'Mountfield vs Honda - which petrol mower to buy?', a: 'Honda for ultimate longevity and refinement (and £400+ more). Mountfield for the best price-to-quality ratio in the £300-£500 bracket. Both will last 10-15 years of typical UK domestic use; Honda will more likely make 20+ with proper servicing.' },
];

const schema = [
  breadcrumbSchema(crumbs),
  articleSchema({ headline: title, description, url: path, datePublished, dateModified: '2026-06-05' }),
  faqSchema(faqs),
  itemListSchema({ name: 'Best Mountfield lawn mowers 2026', url: path, items: picks.map((p, i) => ({ position: i+1, name: p.name, url: p.reviewUrl })) }),
];
---
<BaseLayout {title} {description} {schema}>
  <article class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />
    <header class="mb-8">
      <p class="text-sm font-semibold text-grass-700 uppercase tracking-wide mb-2">Brand guide · Updated May 2026</p>
      <h1 class="text-3xl md:text-5xl font-bold text-soil-900 leading-tight">Mountfield Lawn Mowers</h1>
      <p class="mt-4 text-lg text-slate-700 leading-relaxed">
        Despite the very British name, Mountfield is Italian - owned by the Stiga group out of Castelfranco Veneto. Don't hold that against them. The petrol mowers and ride-ons consistently deliver the best value of any mainstream brand in the UK. SP46 self-propelled at £329? Honest petrol mower, will last fifteen years. 1538M ride-on at £1,799? Honest acre-eater. The new cordless Princess range adds rear-roller stripes from a battery for under £400.
      </p>
    </header>

    <img
      src="/images/lawn_mower_for_gardens.webp"
      alt="Mountfield lawn mower on a striped UK lawn"
      width="900" height="506"
      class="w-full rounded-xl mb-10 object-cover"
      loading="eager"
    />

    <div class="prose-mowers">
      <h2 id="best">Best Mountfield lawn mowers</h2>
      <div class="space-y-6 mt-6">{picks.map((p) => <PickCard {...p} />)}</div>

      <h2 id="vs-rivals">Where Mountfield fits vs rivals</h2>
      <p>
        On petrol push, <strong>Honda</strong> is the premium alternative - better engine, twice the price. <a href="/brands/cobra/">Cobra</a> is the closest direct rival on price. On ride-ons, John Deere is premium; <a href="/brands/stiga/">Stiga</a> (sister brand) is sometimes the same machine with a different sticker. On cordless, Mountfield doesn't really compete with Bosch or Ryobi on cross-tool ecosystems but the Princess 34 occupies the rare cordless-with-rear-roller niche.
      </p>

      <h2 id="related">Related guides</h2>
      <ul>
        <li><a href="/petrol-lawn-mowers/">Best petrol lawn mowers</a></li>
        <li><a href="/ride-on-lawn-mowers/">Best ride-on lawn mowers</a></li>
        <li><a href="/brands/stiga/">Stiga lawn mowers</a></li>
        <li><a href="/brands/cobra/">Cobra lawn mowers</a></li>
      </ul>
    </div>
    <FAQ {faqs} />
  </article>
</BaseLayout>
