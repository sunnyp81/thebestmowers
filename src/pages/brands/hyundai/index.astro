---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import PickCard from '../../../components/PickCard.astro';
import { articleSchema, breadcrumbSchema, faqSchema, itemListSchema } from '../../../lib/schema';

const title = 'Hyundai Lawn Mowers UK - Cheap Petrol Mowers Reviewed';
const description = 'Independent reviews of Hyundai lawn mowers in the UK. Cheap petrol mowers from Hyundai Power Equipment - what works, what doesn\'t, who they\'re for.';
const path = '/brands/hyundai/';
const datePublished = '2026-05-10';

const crumbs = [{ name: 'Home', url: '/' }, { name: 'Brands', url: '/brands/' }, { name: 'Hyundai', url: path }];

const picks = [
  { rank: 1, name: 'Hyundai HYM510SP', brand: 'Hyundai', bestFor: 'cheapest self-propelled petrol', rating: 4.0, rrp: '£269', reviewUrl: '/brands/hyundai/', pros: ['Self-propelled at this price', '51 cm steel deck', '173 cc OHV engine'], cons: ['Engine is generic, not Briggs/Honda', 'After-sales is online-only'], verdict: 'The HYM510SP is the cheapest 51 cm self-propelled petrol mower we trust. The engine is a generic Hyundai-branded OHV - not as refined as Briggs or Honda, but reliable enough for typical UK domestic use. Won\'t outlive you, but works fine for 8-12 years.' },
];

const faqs = [
  { q: 'Are Hyundai lawn mowers any good?', a: 'For the price, decent. Hyundai Power Equipment in the UK is licensed by the Korean Hyundai conglomerate but designed and distributed by a UK company. The petrol mowers use generic Hyundai-branded engines (Chinese-made) which are reliable but not as refined as Briggs & Stratton or Honda. Build quality is honest budget - not premium, but works.' },
  { q: 'Is Hyundai Power Equipment the same as Hyundai cars?', a: 'Same brand licensing, different company. Hyundai Power Equipment in Europe is a UK-based licensee that pays the Korean parent for use of the Hyundai brand. The mowers, generators and other tools are designed and distributed by the UK company; manufacturing is in China.' },
  { q: 'Hyundai vs Cobra petrol mower - which to buy?', a: 'Cobra. Both are budget-mid range, both Chinese-made, but Cobra fits genuine Briggs & Stratton engines on most models - significantly more refined and easier to service than Hyundai\'s own-brand engines. Pay £100 more for the Cobra and you\'ll thank yourself in five years.' },
];

const schema = [
  breadcrumbSchema(crumbs),
  articleSchema({ headline: title, description, url: path, datePublished, dateModified: '2026-06-05' }),
  faqSchema(faqs),
  itemListSchema({ name: 'Best Hyundai lawn mowers 2026', url: path, items: picks.map((p, i) => ({ position: i+1, name: p.name, url: p.reviewUrl })) }),
];
---
<BaseLayout {title} {description} {schema}>
  <article class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />
    <header class="mb-8">
      <p class="text-sm font-semibold text-grass-700 uppercase tracking-wide mb-2">Brand guide · Updated May 2026</p>
      <h1 class="text-3xl md:text-5xl font-bold text-soil-900 leading-tight">Hyundai Lawn Mowers</h1>
      <p class="mt-4 text-lg text-slate-700 leading-relaxed">
        Hyundai lawn mowers in the UK are not made by the Korean car company. They're made by Hyundai Power Equipment, a British company that licences the Hyundai brand and sells generally-decent budget petrol mowers, generators and pressure washers. The mowers use generic own-brand engines - not Briggs or Honda - which is the main thing to know. Cheap, works, won't last twenty years. Honest budget kit.
      </p>
    </header>

    <img
      src="/images/electric_hyundai_lawnmower_model.webp"
      alt="Hyundai electric lawn mower"
      width="900" height="506"
      class="w-full rounded-xl mb-10 object-cover"
      loading="eager"
    />

    <div class="prose-mowers">
      <h2 id="best">Best Hyundai lawn mowers</h2>
      <div class="space-y-6 mt-6">{picks.map((p) => <PickCard {...p} />)}</div>

      <h2 id="related">Related guides</h2>
      <ul>
        <li><a href="/petrol-lawn-mowers/">Best petrol lawn mowers</a></li>
        <li><a href="/brands/cobra/">Cobra lawn mowers (the better budget pick)</a></li>
        <li><a href="/brands/mountfield/">Mountfield lawn mowers</a></li>
      </ul>
    </div>
    <FAQ {faqs} />
  </article>
</BaseLayout>
