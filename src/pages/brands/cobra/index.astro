---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import PickCard from '../../../components/PickCard.astro';
import { articleSchema, breadcrumbSchema, faqSchema, itemListSchema } from '../../../lib/schema';

const title = 'Cobra Lawn Mowers UK - Petrol & Ride-On Range Reviewed';
const description = 'Independent reviews of Cobra lawn mowers. British-designed, Briggs & Stratton-engined petrol mowers and ride-ons that undercut the established names by 30%.';
const path = '/brands/cobra/';
const datePublished = '2026-05-10';

const crumbs = [{ name: 'Home', url: '/' }, { name: 'Brands', url: '/brands/' }, { name: 'Cobra', url: path }];

const picks = [
  { rank: 1, name: 'Cobra MX46SPB', brand: 'Cobra', bestFor: 'mid-range Briggs-engined petrol', rating: 4.4, rrp: '£449', reviewUrl: '/reviews/cobra-mx46spb/', pros: ['Briggs & Stratton 575iS engine', '4-in-1 cut: collect/mulch/discharge/rear', 'Steel deck'], cons: ['Recoil starter only on this model', 'Mid-tier brand recognition'], verdict: 'British-designed, Chinese-built, Briggs-engined - the Cobra formula in one mower. Verified owner reviews report it running for years with no major issues. Best mid-range value in petrol.' },
  { rank: 2, name: 'Cobra LT92HRL', brand: 'Cobra', bestFor: 'budget rear-collection ride-on', rating: 4.2, rrp: '£1,999', reviewUrl: '/ride-on-lawn-mowers/', pros: ['Loncin engine - proven', 'Rear-collection at a budget price', '92 cm deck'], cons: ['Newer brand in this category', 'Smaller dealer footprint'], verdict: 'Cobra entered ride-on in 2019; owner reviews report the range running strong several seasons in. Build is solid for the money. Good first ride-on if you don\'t want to spend £2,500+.' },
];

const faqs = [
  { q: 'Are Cobra lawn mowers any good?', a: 'For the price, yes - Cobra consistently delivers genuine engine quality (Briggs & Stratton on petrol mowers, Loncin on ride-ons) at 25-30% below the established names. The brand is British-designed in Stoke and Chinese-manufactured. Build quality is mid-tier mainstream, not premium, but the engines are real and parts are available through Cobra dealers.' },
  { q: 'Where is Cobra based?', a: 'Cobra Garden Machinery is a UK company headquartered in Staffordshire. Design, distribution and dealer support are UK-based. Manufacturing is contracted to factories in China and the Far East. The brand has grown rapidly since launching in 2014.' },
  { q: 'Cobra vs Mountfield - which to buy?', a: 'Both are mid-range value brands. Mountfield uses Italian-built engines (slightly more refined), broader retail footprint, more brand recognition. Cobra uses Briggs & Stratton (American engines, very widely supported) and undercuts Mountfield by 10-20% on like-for-like models. Both will last 10-15 years; Cobra is the slightly cheaper bet.' },
];

const schema = [
  breadcrumbSchema(crumbs),
  articleSchema({ headline: title, description, url: path, datePublished, dateModified: '2026-06-05' }),
  faqSchema(faqs),
  itemListSchema({ name: 'Best Cobra lawn mowers 2026', url: path, items: picks.map((p, i) => ({ position: i+1, name: p.name, url: p.reviewUrl })) }),
];
---
<BaseLayout {title} {description} {schema}>
  <article class="max-w-4xl mx-auto px-4 py-10">
    <Breadcrumbs items={crumbs} />
    <header class="mb-8">
      <p class="text-sm font-semibold text-grass-700 uppercase tracking-wide mb-2">Brand guide · Updated May 2026</p>
      <h1 class="text-3xl md:text-5xl font-bold text-soil-900 leading-tight">Cobra Lawn Mowers</h1>
      <p class="mt-4 text-lg text-slate-700 leading-relaxed">
        Cobra is the British brand most UK gardeners hadn't heard of in 2014 and now own. The formula is straightforward: design in Staffordshire, manufacture in China, fit Briggs & Stratton engines on the petrol mowers and Loncin on the ride-ons, and undercut Mountfield and Honda by 25%. The result is a range of honestly-built, well-engined garden machines that we genuinely recommend without caveats. Not glamorous. Just good value.
      </p>
    </header>

    <img
      src="/images/powerful_and_efficient_lawnmower.webp"
      alt="Cobra petrol lawn mower cutting a UK lawn"
      width="900" height="506"
      class="w-full rounded-xl mb-10 object-cover"
      loading="eager"
    />

    <div class="prose-mowers">
      <h2 id="best">Best Cobra lawn mowers</h2>
      <div class="space-y-6 mt-6">{picks.map((p) => <PickCard {...p} />)}</div>

      <h2 id="related">Related guides</h2>
      <ul>
        <li><a href="/petrol-lawn-mowers/">Best petrol lawn mowers</a></li>
        <li><a href="/ride-on-lawn-mowers/">Best ride-on lawn mowers</a></li>
        <li><a href="/brands/mountfield/">Mountfield lawn mowers</a></li>
      </ul>
    </div>
    <FAQ {faqs} />
  </article>
</BaseLayout>
